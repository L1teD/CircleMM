# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_BOT_CLIENT_ID=your_discord_bot_client_id
DISCORD_BOT_OWNER_ID=your_discord_id
DISCORD_GUILD_ID=your_guild_id

# Channel IDs
DISCORD_CHANNEL_MATCH_SETUP=channel_id_for_lobby_panel
DISCORD_CHANNEL_SEARCH_OUTPUT=channel_id_for_match_found_announcements
DISCORD_CHANNEL_QUEUE_1v1=voice_channel_id_for_1v1_counter
DISCORD_CHANNEL_QUEUE_2v2=voice_channel_id_for_2v2_counter
DISCORD_CHANNEL_QUEUE_SPAM=channel_id_for_queue_join_leave_spam
DISCORD_CHANNEL_INVITES=channel_id_for_osu_lobby_invite_buttons

# Set to true to re-register slash commands on every startup (dev only)
DISCORD_BOT_REGISTER_ON_START=false

# ── osu! ──────────────────────────────────────────────────────────────────────
OSU_BOT_USERNAME=your_osu_bot_username
OSU_IRC_PASSWORD=your_osu_irc_password
OSU_IRC_API_KEY=your_legacy_api_key
OSU_BOT_CLIENT_ID=123456
OSU_BOT_CLIENT_SECRET=your_osu_client_secret
OSU_BOT_PREFIX=!
OSU_STATE_SECRET=random_secret_for_oauth_state

# Comma-separated osu! user IDs to add as lobby referees
OSU_BOT_REFS=12345,67890

# ── Match settings ─────────────────────────────────────────────────────────────
MATCH_BEST_OF_1v1=7
MATCH_BEST_OF_2v2=9
MATCH_READY_CHECK_TIMEOUT_MS=90000
MATCH_PHASE_TIMEOUT_MS=120000
MATCH_LOBBY_INVITE_INTERVAL_MS=30000
MATCH_LOBBY_CLOSE_TIMEOUT_MS=180000
MATCH_MAX_LIFETIME_MS=7200000
MATCH_TEAM_REJOIN_TIMEOUT_MS=30000
MATCH_ABORT_WINDOW_MS=30000
MATCH_TB_DECISION_TIMEOUT_MS=30000
MATCH_CLEANUP_DELAY_MS=30000
MATCH_MAP_BANS=2
MATCH_POOL_BANS=7

# ── Matchmaking ────────────────────────────────────────────────────────────────
MM_BASE_TOLERANCE=100
MM_MAX_TOLERANCE=300
MM_TOLERANCE_GROWTH_PER_10S=50
MM_SCAN_INTERVAL_MS=1000

# ── Elo ────────────────────────────────────────────────────────────────────────
ELO_DEFAULT=1000
ELO_K_FACTOR_CALIBRATION=40
ELO_K_FACTOR_NORMAL=20
ELO_K_FACTOR_HIGH=10
ELO_CALIBRATION_MATCHES=10
ELO_THRESHOLD_HIGH=2000

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── API ────────────────────────────────────────────────────────────────────────
FASTIFY_PORT=3000
FASTIFY_HOST=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:pass@localhost:3306/circlemm

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
